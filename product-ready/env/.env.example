# --- Core database/cache ---
POSTGRES_USER=cryon
POSTGRES_PASSWORD=change-me-now
POSTGRES_DB=cryon

# Use pinned tags for go-live (sha-<commit> or vX.Y.Z), not latest.
CRYON_SERVER_IMAGE=ghcr.io/01001100-01001001/cryon-chat-server:sha-REPLACE_ME

# --- Runtime tuning ---
CRYON_NQ_INGRESS_ADDR=:4543
CRYON_RAW_INGRESS_ADDR=0.0.0.0:4544
CRYON_DEDUPE_TTL_SECONDS=120
CRYON_HELLO_NONCE_TTL_SECONDS=120
CRYON_HELLO_MAX_SKEW_SECONDS=30
CRYON_SESSION_TTL_SECONDS=43200
CRYON_REQUIRE_ATTESTATION=false

# --- Observability ---
CRYON_OBS_PANEL=true
CRYON_OBS_ADDR=:8585

# --- Host published ports ---
CRYON_NQ_INGRESS_PORT=443
CRYON_OBS_PORT=8585

CRYON_ALLOW_RAW_ONLY_FALLBACK=false
